# Supabase — find these in your project's API settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-jwt

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# UTD Nebula API — https://api.utdnebula.com
NEBULA_API_BASE=https://api.utdnebula.com
NEBULA_API_KEY=your-nebula-api-key

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
